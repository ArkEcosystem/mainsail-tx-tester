{
    "private": true,
    "name": "@mainsail/simple-tx-tester",
    "type": "module",
    "description": "A simple command line utility to create and broadcast transactions.",
    "scripts": {
        "start": "node dist/index.js",
        "message-sign": "node dist/actions/message-sign.js",
        "message-verify": "node dist/actions/message-verify.js",
        "wallet": "node dist/actions/wallet-data.js",
        "validator": "node dist/actions/validator-data.js",
        "fixtures": "node dist/actions/generate-fixtures.js",
        "get-nonce": "node dist/actions/get-nonce.js",
        "build-contract": "node dist/actions/build-contract.js",
        "prepare-contract": "node dist/actions/prepare-contract.js",
        "build": "del dist && tsc",
        "build:watch": "del dist && tsc -w",
        "debug": "node --inspect-brk dist/index.js",
        "clean": "del dist",
        "compile": "./node_modules/typescript/bin/tsc"
    },
    "dependencies": {
        "@mainsail/container": "0.0.1-rc.8",
        "@mainsail/contracts": "0.0.1-rc.8",
        "@mainsail/core": "0.0.1-rc.8",
        "@mainsail/crypto-address-base58": "0.0.1-rc.8",
        "@mainsail/crypto-address-keccak256": "0.0.1-rc.8",
        "@mainsail/crypto-config": "0.0.1-rc.8",
        "@mainsail/crypto-consensus-bls12-381": "0.0.1-rc.8",
        "@mainsail/crypto-hash-bcrypto": "0.0.1-rc.8",
        "@mainsail/crypto-key-pair-ecdsa": "0.0.1-rc.8",
        "@mainsail/crypto-signature-ecdsa": "0.0.1-rc.8",
        "@mainsail/crypto-transaction": "0.0.1-rc.8",
        "@mainsail/crypto-validation": "0.0.1-rc.8",
        "@mainsail/crypto-wif": "0.0.1-rc.8",
        "@mainsail/evm-contracts": "0.0.1-rc.8",
        "@mainsail/kernel": "0.0.1-rc.8",
        "@mainsail/serializer": "0.0.1-rc.8",
        "@mainsail/transactions": "0.0.1-rc.8",
        "@mainsail/utils": "0.0.1-rc.8",
        "@mainsail/validation": "0.0.1-rc.8",
        "bip39": "3.1.0",
        "ethers": "6.16.0",
        "fs-extra": "11.3.4",
        "mainsail-network-config": "https://github.com/ArkEcosystem/mainsail-network-config#7479c6d1a3c9dea62a510a6d74ed4df28eb3e08a",
        "reflect-metadata": "0.2.2",
        "solc": "0.8.34",
        "viem": "2.47.17"
    },
    "devDependencies": {
        "@types/eslint": "9.6.1",
        "@types/eslint-config-prettier": "6.11.3",
        "@types/eslint-plugin-prettier": "3.1.3",
        "del-cli": "7.0.0",
        "depcheck": "1.4.7",
        "eslint": "10.2.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-prettier": "5.5.5",
        "eslint-plugin-simple-import-sort": "13.0.0",
        "prettier": "3.8.3",
        "typescript": "6.0.2"
    },
    "engines": {
        "node": ">=24.x"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@chainsafe/blst",
            "bcrypto",
            "better-sqlite3",
            "bstring",
            "lmdb",
            "msgpackr-extract",
            "nsfw",
            "protobufjs"
        ]
    }
}
